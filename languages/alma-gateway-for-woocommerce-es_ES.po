#. Plugin Name of the plugin
#: alma-gateway-for-woocommerce.php
msgid "Alma - Pay in installments or later for WooCommerce"
msgstr "Alma - Pago a plazos o diferido para WooCommerce"

#. Plugin URI of the plugin
#: alma-gateway-for-woocommerce.php
msgid "https://docs.almapay.com/docs/woocommerce"
msgstr "https://docs.almapay.com/docs/woocommerce"

#. Description of the plugin
#: alma-gateway-for-woocommerce.php
#: includes/Infrastructure/Gateway/AbstractGateway.php:48
#: includes/Infrastructure/Gateway/Backend/AlmaGateway.php:34
msgid "Install Alma and boost your sales! It's simple and guaranteed, your cash flow is secured. 0 commitment, 0 subscription, 0 risk."
msgstr "¡Instale Alma e impulse sus ventas! Es sencillo y está garantizado, su flujo de caja quedará asegurado. 0 compromisos, 0 suscripciones, 0 riesgos."

