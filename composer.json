{
  "name": "alma/alma-gateway-for-woocommerce",
  "description": "Alma - Pay in installments or later for WooCommerce",
  "type": "library",
  "version": "6.0.0-alpha",
  "repositories": [
    {
      "type": "composer",
      "url": "https://wpackagist.org",
      "only": [
        "wpackagist-plugin/*",
        "wpackagist-theme/*"
      ]
    }
  ],
  "require": {
    "php": "~7.4 || ~8.0 || ~8.1 || ~8.2 || ~8.3 || ~8.4",
    "ext-intl": "*",
    "ext-json": "*",
    "ext-openssl": "*",
    "alma/alma-php-client": "3.0.*|dev-feature/3.0",
    "level-2/dice": "^4.0",
    "psr/http-client": "^1"
  },
  "require-dev": {
    "brain/monkey": "^2.0@dev",
    "johnpbloch/wordpress-core": "*",
    "mockery/mockery": "^1.6",
    "php-stubs/woocommerce-stubs": "*",
    "php-stubs/wordpress-stubs": "*",
    "phpcompatibility/php-compatibility": "^9.3",
    "phpstan/extension-installer": "^1.4",
    "phpstan/phpstan": "^1.10",
    "phpunit/phpunit": "*",
    "squizlabs/php_codesniffer": "^3.7",
    "symfony/var-dumper": "*",
    "wp-coding-standards/wpcs": "dev-develop",
    "wpackagist-plugin/woocommerce": "^10.0.4",
    "yoast/phpunit-polyfills": "*"
  },
  "autoload": {
    "psr-4": {
      "Alma\\Gateway\\": "includes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Alma\\Gateway\\Tests\\": "tests/"
    }
  },
  "extra": {
    "installer-disable": [
      "wordpress"
    ],
    "strauss": {
      "target_directory": "vendor-prefixed",
      "namespace_prefix": "Alma\\Vendor",
      "packages": [
        "alma/alma-php-client",
        "level-2/dice"
      ],
      "include_root_autoload": true,
      "delete_vendor_packages": false
    }
  },
  "license": "GPL-3.0-only",
  "authors": [
    {
      "name": "Alma",
      "email": "contact@almapay.com"
    }
  ],
  "scripts": {
    "phpcs": "vendor/bin/phpcs --standard=phpcs.xml .",
    "phpcbf": "vendor/bin/phpcbf --standard=phpcs.xml .",
    "php-compatibility": "vendor/bin/phpcs -p src --standard=PHPCompatibility -s --runtime-set testVersion 7.4-8.4 --ignore=\\*/vendor/\\*"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "automattic/jetpack-autoloader": true,
      "composer/installers": true,
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "phpstan/extension-installer": true
    },
    "lock": false
  },
  "minimum-stability": "dev"
}
