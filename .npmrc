# Declares the private @alma package registry (Google Artifact Registry).
# The registry URL is public config; only the auth token is sensitive, so it is
# NOT stored here: npm substitutes ${NPM_TOKEN} from the environment at install
# time. Supply a short-lived token via NPM_TOKEN (see bin/npm-auth.sh / CI).
@alma:registry=https://europe-npm.pkg.dev/lyrical-carver-335213/node-packages/
//europe-npm.pkg.dev/lyrical-carver-335213/node-packages/:_authToken=${NPM_TOKEN}
//europe-npm.pkg.dev/lyrical-carver-335213/node-packages/:always-auth=true
