#. Plugin Name of the plugin
#: alma-gateway-for-woocommerce.php
msgid "Alma - Pay in installments or later for WooCommerce"
msgstr "Alma - Betalen in termijnen of later voor WooCommerce"

#. Plugin URI of the plugin
#: alma-gateway-for-woocommerce.php
msgid "https://docs.almapay.com/docs/woocommerce"
msgstr "https://docs.almapay.com/docs/woocommerce"

#. Description of the plugin
#: alma-gateway-for-woocommerce.php
msgid "Install Alma and boost your sales! It's simple and guaranteed, your cash flow is secured. 0 commitment, 0 subscription, 0 risk. This version of the plugin is compatible with WooCommerce 10.1.0 and above, and WordPress 6.6 and above. For older versions, please use <a href=\"https://github.com/alma/alma-woocommerce-gateway/releases/tag/v5.16.2\" target=\"_blank\">version 5 of the plugin</a>."
msgstr "Installeer Alma en stimuleer je verkoop! Het is eenvoudig en gegarandeerd, uw cashflow is verzekerd. 0 verplichting, 0 abonnement, 0 risico. Deze versie van de plugin is compatibel met WooCommerce 10.1.0 en hoger, en WordPress 6.6 en hoger. Gebruik voor oudere versies <a href=\"https://github.com/alma/alma-woocommerce-gateway/releases/tag/v5.16.2\" target=\"_blank\">versie 5 van de plugin</a>."

